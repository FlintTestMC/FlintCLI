{
    "name": "multi_event_tick",
    "description": "Exercises the event-step picker (#0040). Tick 1 places, then asserts. Tick 2 asserts, then places. Tick 3 mixes multiple places and asserts.",
    "tags": ["basic", "events"],
    "dependencies": [],
    "setup": {
        "cleanup": {
            "region": [[-5, 95, -5], [5, 105, 5]]
        }
    },
    "timeline": [
        {
            "at": 1,
            "do": "place",
            "pos": [0, 100, 0],
            "block": {"id": "minecraft:stone"}
        },
        {
            "at": 1,
            "do": "assert",
            "checks": [
                {"pos": [0, 100, 0], "is": {"id": "minecraft:stone"}}
            ]
        },
        {
            "at": 2,
            "do": "assert",
            "checks": [
                {"pos": [1, 100, 0], "is": {"id": "minecraft:air"}}
            ]
        },
        {
            "at": 2,
            "do": "place",
            "pos": [1, 100, 0],
            "block": {"id": "minecraft:oak_planks"}
        },
        {
            "at": 3,
            "do": "place",
            "pos": [2, 100, 0],
            "block": {"id": "minecraft:dirt"}
        },
        {
            "at": 3,
            "do": "assert",
            "checks": [
                {"pos": [2, 100, 0], "is": {"id": "minecraft:dirt"}}
            ]
        },
        {
            "at": 3,
            "do": "place",
            "pos": [3, 100, 0],
            "block": {"id": "minecraft:cobblestone"}
        }
    ]
}
